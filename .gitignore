# =========================
# The Vault .gitignore
# =========================

# 1. Security (NEVER PUSH THESE)
.env
.env.*
!.env.example

# 2. Next.js / Frontend
frontend/node_modules/
frontend/.next/
frontend/out/
frontend/build/
frontend/.npm/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# 3. Go / Backend
bin/
obj/
*.exe
*.exe~
*.dll
*.so
*.dylib
*.test
*.out
vendor/
tmp/

# 4. OS / Editor
.DS_Store
Thumbs.db
.vscode/
.idea/