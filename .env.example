# Database (Neon in production)
DATABASE_URL=postgres://vault_user:vault_pass@localhost:5432/the_vault?sslmode=disable

# Redis (Upstash in production)
REDIS_URL=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# Server
PORT=8080
ENV=development

# JWT
JWT_SECRET=your-256-bit-secret-here

# CORS (set to your Vercel URL in production)
CORS_ORIGIN=http://localhost:3000

# SMTP (Email Worker)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@thevault.dev
